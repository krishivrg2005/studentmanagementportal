<%- include("partials/head", { title, bodyClass }) %>
<%- include("partials/nav") %>

<main class="dashboard-shell">
  <section class="dashboard-hero">
    <div>
      <p class="eyebrow">Student Dashboard</p>
      <h1>Your academic journey, organized.</h1>
      <p class="hero-copy">
        Keep your profile up to date, enroll in courses, review attendance and grades, and stay ahead on fees.
      </p>
    </div>
    <div class="hero-badge">
      <span><%= student.department %></span>
      <strong><%= student.name %></strong>
      <small><%= student.rollNumber %></small>
    </div>
  </section>

  <%- include("partials/flash") %>

  <section class="stats-grid">
    <article class="stat-card tone-teal">
      <p>Enrolled Courses</p>
      <h2><%= metrics.enrolledCourses %></h2>
    </article>
    <article class="stat-card tone-amber">
      <p>Attendance Rate</p>
      <h2><%= metrics.attendanceRate %>%</h2>
    </article>
    <article class="stat-card tone-slate">
      <p>Average Marks</p>
      <h2><%= metrics.averageMarks || "NA" %></h2>
    </article>
    <article class="stat-card tone-rose">
      <p>Pending Fees</p>
      <h2><%= new Intl.NumberFormat("en-IN", { style: "currency", currency: "INR", maximumFractionDigits: 0 }).format(metrics.pendingFees) %></h2>
    </article>
  </section>

  <section class="content-grid">
    <article class="panel" id="profile">
      <div class="panel-heading">
        <p class="eyebrow">Profile</p>
        <h2>Student information</h2>
      </div>
      <form class="stack-form" action="/student/profile" method="post">
        <div class="form-grid">
          <label><span>Name</span><input name="name" value="<%= student.name %>" required /></label>
          <label><span>Email</span><input value="<%= student.email %>" disabled /></label>
          <label><span>Registration number</span><input value="<%= student.rollNumber %>" disabled /></label>
          <label><span>Department</span><input name="department" value="<%= student.department %>" /></label>
          <label><span>Year</span><input name="year" value="<%= student.year %>" /></label>
          <label><span>Phone</span><input name="phone" value="<%= student.phone %>" /></label>
          <label class="full-span"><span>Guardian name</span><input name="guardianName" value="<%= student.guardianName %>" /></label>
        </div>
        <button class="button-primary" type="submit">Update Profile</button>
      </form>
    </article>

    <article class="panel">
      <div class="panel-heading">
        <p class="eyebrow">Course Enrollment</p>
        <h2>Available courses</h2>
      </div>
      <div class="card-list">
        <% if (!availableCourses.length) { %>
          <p class="empty-state">You are already enrolled in every available course.</p>
        <% } %>
        <% availableCourses.forEach((course) => { %>
          <div class="catalog-card">
            <div>
              <strong><%= course.code %> · <%= course.title %></strong>
              <p><%= course.department %> · <%= course.credits %> credits · <%= course.facultyName %></p>
              <small><%= course.enrolledCount %> / <%= course.capacity %> enrolled</small>
            </div>
            <form action="/student/enroll" method="post">
              <input type="hidden" name="courseId" value="<%= course.id %>" />
              <button class="button-secondary" type="submit">Enroll</button>
            </form>
          </div>
        <% }) %>
      </div>
    </article>
  </section>

  <section class="table-grid">
    <article class="panel">
      <div class="panel-heading">
        <p class="eyebrow">Academic Progress</p>
        <h2>Current courses</h2>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Course</th>
              <th>Faculty</th>
              <th>Attendance</th>
              <th>Latest Grade</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% if (!enrolledCourses.length) { %>
              <tr>
                <td colspan="5">
                  <span>No active course enrollments yet.</span>
                </td>
              </tr>
            <% } %>
            <% enrolledCourses.forEach((entry) => { %>
              <tr>
                <td>
                  <strong><%= entry.course.code %></strong>
                  <span><%= entry.course.title %></span>
                </td>
                <td><%= entry.faculty?.name || "Unassigned" %></td>
                <td><%= entry.attendanceRate %>%</td>
                <td>
                  <% if (entry.latestAssessment) { %>
                    <strong><%= entry.latestAssessment.marks %> (<%= entry.latestAssessment.gradeLetter %>)</strong>
                    <span><%= entry.latestAssessment.assessment %></span>
                  <% } else { %>
                    <span>Awaiting grades</span>
                  <% } %>
                </td>
                <td>
                  <form action="/student/withdraw" method="post">
                    <input type="hidden" name="courseId" value="<%= entry.courseId %>" />
                    <button class="button-secondary" type="submit">Withdraw</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </article>

    <article class="panel">
      <div class="panel-heading">
        <p class="eyebrow">Fees</p>
        <h2>Payment records</h2>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Term</th>
              <th>Due Date</th>
              <th>Amount</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% payments.forEach((payment) => { %>
              <tr>
                <td><%= payment.term %></td>
                <td><%= payment.dueDate %></td>
                <td><%= payment.amountLabel %></td>
                <td><span class="status-pill status-<%= payment.status.toLowerCase() %>"><%= payment.status %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </article>
  </section>
</main>

</body>
</html>
