<header class="site-header">
  <div class="brand-block">
    <div class="brand-mark">SM</div>
    <div>
      <p class="eyebrow">University Portal</p>
      <a class="brand-name" href="/">Student Management Portal</a>
    </div>
  </div>

  <nav class="site-nav">
    <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle color theme" aria-pressed="false">
      <span class="theme-toggle-icon" aria-hidden="true">☀</span>
      <span class="theme-toggle-label">Light</span>
    </button>
    <% if (currentUser) { %>
      <a href="/dashboard">Dashboard</a>
      <% if (currentUser.role === "student") { %>
        <a href="/student/dashboard#profile">Profile</a>
      <% } %>
      <a href="/logout">Logout</a>
    <% } else { %>
      <a href="/login">Login</a>
      <a href="/register">Register</a>
    <% } %>
  </nav>
</header>
